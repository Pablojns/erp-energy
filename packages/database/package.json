{
  "name": "@erp/database",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "prisma generate --schema ./prisma/schema.prisma && tsc -p tsconfig.json",
    "lint": "prisma generate --schema ./prisma/schema.prisma && tsc --noEmit -p tsconfig.json",
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ./prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "db:studio": "prisma studio --schema ./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prisma": "^6.16.3",
    "typescript": "^5.9.3"
  }
}
