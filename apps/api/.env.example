NODE_ENV="development"
PORT=3001
# true = API aceita rotas protegidas sem JWT (somente dev)
AUTH_DISABLED=false
DATABASE_URL="postgresql://erp_user:erp_password@localhost:5432/erp_dev?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-this-secret-in-production"
JWT_EXPIRES_IN="1d"
ADMIN_NAME="ERP Admin"
ADMIN_EMAIL="admin@erp.local"
ADMIN_PASSWORD="Admin@123"

# Future integrations
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
