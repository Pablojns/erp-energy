NODE_ENV="development"
PORT=3001
# true = API aceita rotas protegidas sem JWT (somente dev)
AUTH_DISABLED=false
DATABASE_URL="postgresql://erp_user:erp_password@localhost:5432/erp_dev?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-this-secret-in-production"
JWT_EXPIRES_IN="1d"
ADMIN_NAME="ERP Admin"
ADMIN_EMAIL="admin@erp.local"
ADMIN_PASSWORD="Admin@123"

# Future integrations
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Correios (PPN) — use producao em ambiente real
CORREIOS_ENV=producao
CORREIOS_USUARIO=
CORREIOS_SENHA_COMPONENTE=
CORREIOS_CARTAO_POSTAGEM=
CORREIOS_CONTRATO=
CORREIOS_CEP_ORIGEM=
# Códigos de serviço do contrato (cartão AG). Ajuste se o contrato mudar.
CORREIOS_CODIGO_PAC=03298
CORREIOS_CODIGO_SEDEX=03220
CORREIOS_CODIGO_MINI_ENVIOS=04227

# SPOT (Stricker Europe) — catálogo de orçamentos
SPOT_ACCESS_KEY=
SPOT_CLIENT_ID=
SPOT_BASE_URL=https://ws.spotgifts.com.br/api/v1SSL
